{
  "name": "trading-dashboard",
  "version": "1.4.90",
  "private": true,
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "set NODE_ENV=development && electron electron.cjs",
    "dist": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.8.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.trading.dashboard",
    "productName": "Trading Dashboard",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "CHEMSOUZ",
      "repo": "trading-dashboard",
      "releaseType": "release"
    },
    "files": [
      "dist/index.html",
      "dist/assets/**/*",
      "dist/favicon.svg",
      "electron.cjs",
      "preload.cjs",
      "database.cjs",
      "accounts.cjs"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
