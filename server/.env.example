# ── Serveur ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Origine autorisee pour CORS (mettre l'URL exacte du client en prod, "*" en dev)
ALLOWED_ORIGIN=*

# ── Authentification ─────────────────────────────────────
# Chaine longue et aleatoire (ex: openssl rand -hex 64) -- ne JAMAIS commiter la vraie valeur
JWT_SECRET=change_me_to_a_long_random_secret
# Duree de vie du JWT. Pas de refresh token a cette etape : au-dela, l'utilisateur doit se reconnecter.
JWT_EXPIRES_IN=7d
# Cout du hash bcrypt (10-12 recommande)
BCRYPT_SALT_ROUNDS=10

# ── Anthropic (cle serveur, jamais exposee au client) ────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Base de donnees ───────────────────────────────────────
DATABASE_PATH=./data/app.db

# Les limites de quota par plan (PLAN_LIMITS) sont definies en dur dans
# src/services/usageService.js et ne sont volontairement pas configurables via env a ce stade.
